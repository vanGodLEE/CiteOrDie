# ==================== LLM閰嶇疆 ====================
# LLM鎻愪緵鍟嗛€夋嫨锛歰penai / deepseek / azure
LLM_PROVIDER=openai

# OpenAI閰嶇疆锛堜娇鐢∣penAI鎴栧吋瀹笰PI鏃跺～鍐欙級
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-2024-08-06

# DeepSeek閰嶇疆锛堜娇鐢―eepSeek鏃跺～鍐欙紝鎺ㄨ崘鐢ㄤ簬涓枃鏂囨。锛?DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen瑙嗚妯″瀷閰嶇疆锛堢敤浜庡浘鐗?琛ㄦ牸鍒嗘瀽锛屽彲閫夛級
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max-latest

# ==================== 鑺傜偣绾LM閰嶇疆 ====================
# 姣忎釜LangGraph鑺傜偣鍙互浣跨敤涓嶅悓鐨勬ā鍨?# 鏍煎紡锛歱rovider:model 鎴?model锛堜娇鐢ㄩ粯璁rovider锛?STRUCTURIZER_MODEL=deepseek:deepseek-chat
TEXT_FILLER_MODEL=deepseek:deepseek-chat
SUMMARY_MODEL=deepseek:deepseek-chat
EXTRACTOR_MODEL=deepseek:deepseek-chat
AUDITOR_MODEL=deepseek:deepseek-chat
VISION_MODEL=qwen:qwen-vl-max-latest

# 429闄愭祦闄嶇骇澶囩敤妯″瀷锛堥€楀彿鍒嗛殧锛屽彲閫夛級
FALLBACK_MODELS=

# ==================== 搴旂敤閰嶇疆 ====================
APP_ENV=development
LOG_LEVEL=INFO
TEMP_DIR=./temp

# ==================== FastAPI閰嶇疆 ====================
API_HOST=0.0.0.0
API_PORT=8000
# CORS鍏佽鐨勬潵婧愶紙閫楀彿鍒嗛殧锛夛紝寮€鍙戠幆澧冨彲浠ョ敤*
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== MinIO閰嶇疆锛堝璞″瓨鍌級 ====================
# MinIO鏈嶅姟鍣ㄥ湴鍧€锛圫3 API绔彛锛屼笉鍚玥ttp://鍓嶇紑锛?MINIO_ENDPOINT=localhost:9000
# MinIO璁块棶鍑瘉锛堥粯璁や负minioadmin/minioadmin锛?MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# MinIO瀛樺偍妗跺悕绉?MINIO_BUCKET=document-pdf
# 鏄惁浣跨敤HTTPS杩炴帴MinIO
MINIO_SECURE=false

# ==================== 涓氬姟閰嶇疆 ====================
# 鏈€澶у苟琛學orker鏁伴噺锛堟帶鍒禠angGraph骞跺彂搴︼級
MAX_PARALLEL_WORKERS=5
# 鏉℃鎻愬彇鐨勬渶浣庣疆淇″害闃堝€?CONFIDENCE_THRESHOLD=0.5
# 鍘婚噸鏃剁殑鐩镐技搴﹂槇鍊?SIMILARITY_THRESHOLD=0.85

# ==================== 蹇€熷紑濮嬫寚鍗?====================
# 1. 瀹夎渚濊禆锛歱ip install -r requirements.txt
# 2. 瀹夎骞跺惎鍔∕inIO锛?#    - Docker鏂瑰紡锛歞ocker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
#    - 鎴栦笅杞戒簩杩涘埗锛歨ttps://min.io/download
# 3. 閰嶇疆LLM API瀵嗛挜锛堣嚦灏戦厤缃竴涓級
# 4. 鍚姩鏈嶅姟锛歶vicorn app.api.main:app --reload --port 8000
# 5. 璁块棶API鏂囨。锛歨ttp://localhost:8000/docs
