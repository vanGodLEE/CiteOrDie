# ==================== LLM提供商配置 ====================
# 选择使用的LLM提供商：openai / deepseek
LLM_PROVIDER=deepseek

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek API配置
# 可以使用DeepSeek官方API，也可以使用兼容的API（如阿里云通义千问）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 示例：使用阿里云通义千问（兼容OpenAI API格式）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_MODEL=qwen-plus-latest

# ==================== LangGraph节点级模型配置 ====================
# 每个节点可以使用不同的模型，格式：provider:model 或 model
# 例如：deepseek:deepseek-chat 或 openai:gpt-4o 或 qwen-plus-latest

# PageIndex文档解析节点（结构化提取）
# 推荐：使用推理能力强的模型，如deepseek-reasoner或gpt-4o
STRUCTURIZER_MODEL=deepseek:deepseek-chat

# 429限流降级备用模型（仅对PageIndex文档解析生效）
# 逗号分隔，当主模型遇到429限流时自动轮换
# 示例：qwen3-max-preview,qwen-max,qwen-plus-latest
# 留空表示不启用自动降级
FALLBACK_MODELS=

# Text Filler节点（原文摘抄）
# 推荐：使用遵循指令能力强的模型，temperature=0，避免幻觉
TEXT_FILLER_MODEL=deepseek:deepseek-chat

# Summary生成（摘要生成）
# 推荐：使用通用模型即可，temperature=0.3
SUMMARY_MODEL=deepseek:deepseek-chat

# Enricher节点（需求提取）
# 推荐：使用理解能力强的模型，需要准确理解招标需求
EXTRACTOR_MODEL=deepseek:deepseek-chat

# Auditor节点（需求汇总）
# 目前此节点不使用LLM，仅做排序和格式化
AUDITOR_MODEL=deepseek:deepseek-chat

# ==================== 应用配置 ====================
APP_ENV=development
LOG_LEVEL=INFO
TEMP_DIR=./temp

# ==================== FastAPI配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ==================== MinIO配置 ====================
# 注意：MINIO_ENDPOINT应该使用S3 API端口（通常是9000或19000），而不是Web Console端口（通常是9001或19001）
# 如果不确定，请咨询MinIO管理员或尝试端口19000
MINIO_ENDPOINT=192.168.100.219:19000
MINIO_ACCESS_KEY=rag_flow
MINIO_SECRET_KEY=infini_rag_flow
MINIO_BUCKET=tender-pdf
MINIO_SECURE=false
